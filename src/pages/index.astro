<style>

*{
margin:0;
padding:0;
box-sizing:border-box;
}

html{
scroll-behavior:smooth;
}

body{

background:#0e0e0e;

color:white;

font-family:'Cormorant Garamond',serif;

overflow-x:hidden;

}

nav{

position:fixed;

top:0;

left:0;

width:100%;

padding:25px 60px;

display:flex;

justify-content:space-between;

align-items:center;

background:rgba(0,0,0,.35);

backdrop-filter:blur(12px);

z-index:999;

}

nav a{

color:white;

text-decoration:none;

margin-left:40px;

font-size:18px;

letter-spacing:1px;

}

.logo{

font-size:30px;

font-weight:500;

}

.hero{

height:100vh;

background:

linear-gradient(rgba(0,0,0,.35),rgba(0,0,0,.7)),

url("/images/photo.jpg");

background-size:cover;

background-position:center;

display:flex;

align-items:flex-end;

padding-left:10%;

padding-bottom:10%;

}

.hero-text{

max-width:650px;

animation:fade 2s ease;

}

h1{

font-size:95px;

font-weight:400;

letter-spacing:3px;

}

.subtitle{

font-size:34px;

margin-top:10px;

color:#dddddd;

}

.desc{

margin-top:35px;

font-size:22px;

line-height:1.7;

color:#d5d5d5;

max-width:520px;

}

.scroll{

margin-top:50px;

letter-spacing:5px;

font-size:16px;

opacity:.8;

}

section{

padding:140px 10%;

}

h2{

font-size:60px;

margin-bottom:40px;

}

.card{

max-width:800px;

padding:40px;

background:#1a1a1a;

border-radius:12px;

margin-top:30px;

}

.card h3{

font-size:34px;

margin-bottom:15px;

}

.card p{

font-size:22px;

line-height:1.8;

color:#cccccc;

}

footer{

padding:80px;

text-align:center;

color:#888;

}

@keyframes fade{

from{

opacity:0;

transform:translateY(40px);

}

to{

opacity:1;

transform:translateY(0);

}

}

</style>

</head>

